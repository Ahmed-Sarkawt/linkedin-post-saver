{
  "manifest_version": 3,
  "name": "LinkedIn Post Saver",
  "version": "1.0.0",
  "description": "Save LinkedIn posts to your Notion database with AI-generated titles and tags.",
  "permissions": [],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/feed*", "https://www.linkedin.com/in/*", "https://www.linkedin.com/posts/*", "https://www.linkedin.com/company/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}